# Agent configuration — sourced by start-agent.sh and scripts.
# All vars are auto-exported (set -a) so MCP servers and child processes inherit them.
# Edit these values after running /setup, or set them manually.

AGENT_SESSION_NAME="atlas"
AGENT_CHANNEL="mcp:atlas-discord"

# Discord bot config lives in .mcp.json (gitignored).
# Token and owner ID are set there, not here.
