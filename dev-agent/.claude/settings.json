{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "ask": ["Bash(gh pr comment *)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/index-daily-logs.py 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/sync-check.py 2>&1 || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/scan-missed-delegations.py --range 7 2>&1 || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/workspace-scan.py 2>&1 || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/scan-self-audit.py 2>&1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/context-injector.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/delegation-scope-hook.py"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/repo-aware-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/log-commit.py 2>&1 || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/session-snapshot.py SessionEnd 2>&1 || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/session-end-sync.py 2>&1 || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/session-snapshot.py PreCompact 2>&1 || true"
          },
          {
            "type": "command",
            "command": "echo 'Context is about to compact. Run /distill-session now if this session had substantive learnings worth capturing (commit metadata + activity snapshot already auto-captured).'"
          }
        ]
      }
    ]
  }
}
