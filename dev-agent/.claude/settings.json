{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "ask": ["Bash(gh pr comment *)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/index-daily-logs.py 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
