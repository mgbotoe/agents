# Per-machine secrets + paths for Polaris. Copy to config/secrets.env (gitignored)
# on each machine and fill in. Source it from your shell profile so MCP servers
# and scripts inherit the values:
#
#   Windows (PowerShell $PROFILE):  Get-Content config/secrets.env | ... (or set manually)
#   Mac/Linux (~/.zshrc):           set -a; source /path/to/dev-agent/config/secrets.env; set +a
#
# bin/start-agent.sh already sources config/agent.env; secrets.env is the
# secret-bearing counterpart kept out of git.

# Absolute path to THIS dev-agent repo on this machine.
#   Windows: C:/Workspace/agents/dev-agent
#   Mac:     /Users/<you>/Workspace/agents/dev-agent
POLARIS_DEV_AGENT=

# Optional: override the auto-derived workspace root (parent of agents/).
# Leave blank to let scripts derive it from the repo location.
POLARIS_WORKSPACE_ROOT=

# Slack bot tokens (xoxb-...). These were never committed; pull them from your
# existing local .mcp.json on the Windows box, or Windows Credential Manager
# (service "wdai-slack"), or regenerate in the Slack app config.
POLARIS_SLACK_TOKEN=
WDAI_SLACK_TOKEN=
