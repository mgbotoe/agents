# Normalize line endings so Windows + Mac don't churn the diff.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# POSIX scripts must stay LF even when checked out on Windows.
*.sh text eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
