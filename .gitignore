# Secrets
.mcp.json
.env
**/config/secrets/

# Runtime
**/.claude/memory.db
**/.claude/runtime/
**/.claude/edit-log.txt

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.cursor/

# Temp
**/tmp/
**/.tmp/

# Scheduler lock files (per-session, transient)
**/scheduled_tasks.lock

# Throwaway screenshots at repo/agent root — commit to docs/ instead
dev-agent/*.png
chief-of-staff/*.png

# Node
**/node_modules/

# Data files (large JSON exports)
*.json
!**/package.json
!**/bun.lock
!**/.obsidian/*.json
!**/tsconfig.json
!**/.claude/settings.json

# Binary artifacts (pptx, xlsx — should be on GDrive, not git)
*.pptx
*.xlsx
~$*

# Playwright MCP logs
**/.playwright-mcp/

# Slack watcher runtime
slack-watcher/watcher.log
slack-watcher/sessions/
slack-watcher/watcher-*.log
slack-watcher/watcher-*.txt
slack-watcher/startup-*.txt
slack-watcher/*.pid
slack-watcher/*.vbs
chief-of-staff/watcher-*.log

# Raw wiki sources (tracked separately if needed)
wiki/raw/

# Nested external repos cloned for reference (not part of this monorepo)
open-design/

# Python cache
**/__pycache__/
*.pyc

# Agent scratch + scan cache
**/.claude/drafts/
**/.claude/state/website-scan/

# Throwaway HTML at agent root (commit to docs/ instead — mirrors the *.png rule)
dev-agent/*.html
chief-of-staff/*.html
